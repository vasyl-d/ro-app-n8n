{
  "name": "n8n-nodes-roapp",
  "version": "1.0.13",
  "description": "package for roapp.io/orderry.com API",
  "license": "MIT",
  "homepage": "https://github.com/vasyl-d/ro-app-n8n#readme",
  "keywords": [
    "n8n-nodes-roapp",
    "n8n-community-node-package",
    "roapp.io",
    "orderry.com",
    "orderry","roapp","crm"
  ],
  "author": {
    "name": "vasyl-d",
    "email": "vasyld.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vasyl-d/ro-app-n8n.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RoappApi.credentials.js",
      "dist/credentials/OrderryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Roapp/Roapp.node.js",
      "dist/nodes/Orderry/Orderry.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/luxon": "^3.7.1",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.3",
    "release-it": "^20.0.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
